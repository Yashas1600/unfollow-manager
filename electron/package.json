{
  "name": "unfollow-manager",
  "version": "1.0.0",
  "description": "Find and remove Instagram accounts that don't follow you back",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.unfollowmanager.app",
    "productName": "Unfollow Manager",
    "directories": {
      "output": "../dist"
    },
    "extraResources": [
      {
        "from": "../backend_dist/",
        "to": "backend",
        "filter": ["**/*"]
      },
      {
        "from": "../browsers/",
        "to": "browsers",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.social-networking",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  },
  "author": "Yashas",
  "dependencies": {},
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
